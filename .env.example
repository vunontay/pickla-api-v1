# Database
DATABASE_URL=postgresql+asyncpg://pickla:pickla@postgres:5432/pickla
TEST_DATABASE_URL=postgresql+asyncpg://pickla:pickla@postgres:5432/pickla_test

# Redis
REDIS_URL=redis://redis:6379

# App
APP_NAME=Pickla API V1
ENVIRONMENT=dev    # dev | stg | prod
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Better Stack Logs — omit in dev (console only). Required when ENVIRONMENT is stg|prod.
# Source token and ingestion host from the log source in Better Stack.
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGEST_HOST=
